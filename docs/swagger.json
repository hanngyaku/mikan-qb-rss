{
    "swagger": "2.0",
    "info": {
        "description": "qBittorrent RSS 管理工具 API",
        "title": "Mikan qBittorrent RSS API",
        "contact": {},
        "version": "0.1"
    },
    "basePath": "/api",
    "paths": {
        "/qb/test": {
            "post": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "qbittorrent"
                ],
                "summary": "测试 qBittorrent 连接",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.QBTestResponse"
                        }
                    }
                }
            }
        },
        "/settings": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "settings"
                ],
                "summary": "获取设置（不返回密码）",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.SettingsResponse"
                        }
                    }
                }
            },
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "settings"
                ],
                "summary": "更新设置，空密码保留原密码",
                "parameters": [
                    {
                        "description": "设置",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.UpdateSettingsRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.SettingsResponse"
                        }
                    }
                }
            }
        },
        "/subscriptions": {
            "get": {
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "subscriptions"
                ],
                "summary": "订阅列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/model.Subscription"
                            }
                        }
                    }
                }
            },
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "subscriptions"
                ],
                "summary": "添加订阅并同步 qBittorrent",
                "parameters": [
                    {
                        "description": "订阅",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.CreateSubscriptionRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/model.Subscription"
                        }
                    }
                }
            }
        },
        "/subscriptions/{id}": {
            "put": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "subscriptions"
                ],
                "summary": "更新订阅并同步 qBittorrent",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "订阅 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "订阅",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.UpdateSubscriptionRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.Subscription"
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "subscriptions"
                ],
                "summary": "删除订阅及 qBittorrent RSS 配置",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "订阅 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    }
                }
            }
        },
        "/subscriptions/{id}/sync": {
            "post": {
                "tags": [
                    "subscriptions"
                ],
                "summary": "重新同步订阅到 qBittorrent",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "订阅 ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.Subscription"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "model.CreateSubscriptionRequest": {
            "type": "object",
            "properties": {
                "customDirName": {
                    "type": "string"
                },
                "regex": {
                    "type": "string"
                },
                "rssUrl": {
                    "type": "string"
                },
                "season": {
                    "type": "integer"
                }
            }
        },
        "model.QBTestResponse": {
            "type": "object",
            "properties": {
                "connected": {
                    "type": "boolean"
                },
                "version": {
                    "type": "string"
                },
                "webApiVersion": {
                    "type": "string"
                }
            }
        },
        "model.SettingsResponse": {
            "type": "object",
            "properties": {
                "defaultCategory": {
                    "type": "string"
                },
                "downloadRoot": {
                    "type": "string"
                },
                "passwordSet": {
                    "type": "boolean"
                },
                "qbUrl": {
                    "type": "string"
                },
                "qbUsername": {
                    "type": "string"
                },
                "rssInterval": {
                    "type": "integer"
                }
            }
        },
        "model.Subscription": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "enabled": {
                    "type": "boolean"
                },
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "rawTitle": {
                    "type": "string"
                },
                "regex": {
                    "type": "string"
                },
                "rssUrl": {
                    "type": "string"
                },
                "ruleName": {
                    "type": "string"
                },
                "saveDirName": {
                    "type": "string"
                },
                "savePath": {
                    "type": "string"
                },
                "season": {
                    "type": "integer"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "model.UpdateSettingsRequest": {
            "type": "object",
            "properties": {
                "defaultCategory": {
                    "type": "string"
                },
                "downloadRoot": {
                    "type": "string"
                },
                "qbPassword": {
                    "type": "string"
                },
                "qbUrl": {
                    "type": "string"
                },
                "qbUsername": {
                    "type": "string"
                },
                "rssInterval": {
                    "type": "integer"
                }
            }
        },
        "model.UpdateSubscriptionRequest": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "regex": {
                    "type": "string"
                },
                "rssUrl": {
                    "type": "string"
                },
                "saveDirName": {
                    "type": "string"
                },
                "season": {
                    "type": "integer"
                }
            }
        }
    }
}